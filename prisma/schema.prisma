// ✅ schema.prisma unificado — Chef do Cotidiano

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoUsuario {
  ADMIN
  ALUNO
}

enum TipoNotificacao {
  CERTIFICADO
  COMENTARIO
  AULA_CONCLUIDA
  RESPOSTA
  NOVO_CURSO
}

enum CanalNotificacao {
  EMAIL
  WHATSAPP
}

model Usuario {
  id          String           @id @default(uuid())
  nome        String
  email       String           @unique
  senha       String?
  tipo        TipoUsuario      @default(ALUNO)
  criadoEm    DateTime         @default(now())

  inscricoes  Inscricao[]
  progresso   Progresso[]
  favoritos   Favorito[]
  certificados Certificado[]
  comentarios Comentario[]
  notificacoes Notificacao[]
  auditorias  Auditoria[]
  preferencias Preferencia?
}

model Curso {
  id        String   @id @default(uuid())
  titulo    String
  descricao String
  imagem_url String
  criadoEm  DateTime @default(now())
  aulas     Aula[]
  inscricoes Inscricao[]
  certificados Certificado[]
}

model Aula {
  id        String   @id @default(uuid())
  titulo    String
  ordem     Int
  video_url String
  cursoId   String
  curso     Curso     @relation(fields: [cursoId], references: [id])
  progresso Progresso[]
  comentarios Comentario[]
}

model Receita {
  id          String   @id @default(uuid())
  titulo      String
  descricao   String
  imagem_url  String
  criadoEm    DateTime @default(now())
  autorId     String?
  autor       Usuario? @relation(fields: [autorId], references: [id])
  favoritos   Favorito[]
}

model Inscricao {
  id       String   @id @default(uuid())
  userId   String
  cursoId  String
  criadoEm DateTime @default(now())
  usuario  Usuario  @relation(fields: [userId], references: [id])
  curso    Curso    @relation(fields: [cursoId], references: [id])
}

model Progresso {
  id        String   @id @default(uuid())
  userId    String
  aulaId    String
  concluida Boolean  @default(false)
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [userId], references: [id])
  aula      Aula     @relation(fields: [aulaId], references: [id])
}

model Favorito {
  id         String   @id @default(uuid())
  userId     String
  receitaId  String
  criadoEm   DateTime @default(now())

  usuario    Usuario  @relation(fields: [userId], references: [id])
  receita    Receita  @relation(fields: [receitaId], references: [id])
}

model Comentario {
  id         String   @id @default(uuid())
  userId     String
  aulaId     String
  texto      String
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  usuario    Usuario  @relation(fields: [userId], references: [id])
  aula       Aula     @relation(fields: [aulaId], references: [id])
}

model Certificado {
  id         String   @id @default(uuid())
  userId     String
  cursoId    String
  token      String   @unique
  criadoEm   DateTime @default(now())

  usuario    Usuario  @relation(fields: [userId], references: [id])
  curso      Curso    @relation(fields: [cursoId], references: [id])
  auditorias Auditoria[]
}

model Auditoria {
  id            String   @id @default(uuid())
  certificadoId String
  ip            String
  userAgent     String
  criadoEm      DateTime @default(now())
  usuarioId     String?

  certificado   Certificado @relation(fields: [certificadoId], references: [id])
  usuario       Usuario?    @relation(fields: [usuarioId], references: [id])
}

model Preferencia {
  id        String   @id @default(uuid())
  userId    String   @unique
  email     Boolean  @default(true)
  whatsapp  Boolean  @default(false)

  usuario   Usuario  @relation(fields: [userId], references: [id])
}

model Notificacao {
  id         String   @id @default(uuid())
  userId     String
  titulo     String
  mensagem   String
  tipo       TipoNotificacao
  canal      CanalNotificacao
  criadoEm   DateTime @default(now())

  usuario    Usuario  @relation(fields: [userId], references: [id])
}

model IpBloqueado {
  id        String   @id @default(uuid())
  ip        String   @unique
  tentativas Int     @default(1)
  bloqueado Boolean  @default(false)
  criadoEm  DateTime @default(now())
}


