// ✅ schema.prisma unificado — Chef do Cotidiano

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id               String        @id @default(uuid())
  nome             String
  email            String        @unique
  senha            String?
  telefone         String?       // ✅ ADICIONADO
  tipo             TipoUsuario   @default(ALUNO)
  notificaEmail    Boolean       @default(true)    // ✅ ADICIONADO
  notificaWhatsapp Boolean       @default(false)   // ✅ ADICIONADO
  criadoEm         DateTime      @default(now())
  atualizacoes     DateTime[]    @default([])

  // Relacionamentos
  cursos       Curso[]       @relation("AutorCursos")
  inscricoes   Inscricao[]
  progresso    Progresso[]
  favoritos    Favorito[]
  receitas     Receita[]     @relation("AutorReceitas")
  comentarios  Comentario[]
  certificados Certificado[]
  auditorias   Auditoria[]
  notificacoes Notificacao[]
}

model Curso {
  id         String     @id @default(uuid())
  titulo     String
  descricao  String
  imagem_url String
  criadoEm   DateTime   @default(now())
  autorId    String

  // Relacionamentos
  aulas      Aula[]
  autor      Usuario     @relation("AutorCursos", fields: [autorId], references: [id])
  inscricoes Inscricao[]
  certificados Certificado[]
}

model Aula {
  id         String     @id @default(uuid())
  titulo     String
  ordem      Int
  video_url  String
  cursoId    String
  criadoEm   DateTime   @default(now())

  curso      Curso      @relation(fields: [cursoId], references: [id])
  progresso  Progresso[]
  comentarios Comentario[]
}

model Inscricao {
  id       String   @id @default(uuid())
  userId   String
  cursoId  String
  criadoEm DateTime @default(now())

  usuario  Usuario  @relation(fields: [userId], references: [id])
  curso    Curso    @relation(fields: [cursoId], references: [id])
}

model Progresso {
  id        String   @id @default(uuid())
  userId    String
  aulaId    String
  concluida Boolean  @default(false)
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [userId], references: [id])
  aula      Aula     @relation(fields: [aulaId], references: [id])
}

model Receita {
  id         String    @id @default(uuid())
  titulo     String
  descricao  String
  imagem_url String
  criadoEm   DateTime  @default(now())
  autorId    String

  autor      Usuario   @relation("AutorReceitas", fields: [autorId], references: [id])
  favoritos  Favorito[]
}

model Favorito {
  id         String   @id @default(uuid())
  userId     String
  receitaId  String
  criadoEm   DateTime @default(now())

  usuario    Usuario  @relation(fields: [userId], references: [id])
  receita    Receita  @relation(fields: [receitaId], references: [id])
}

model Comentario {
  id        String   @id @default(uuid())
  mensagem  String
  criadoEm  DateTime @default(now())
  usuarioId String
  aulaId    String

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  aula      Aula     @relation(fields: [aulaId], references: [id])
}

model Certificado {
  id         String   @id @default(uuid())
  token      String   @unique
  cursoId    String
  userId     String
  criadoEm   DateTime @default(now())
  valido     Boolean  @default(true)

  curso      Curso    @relation(fields: [cursoId], references: [id])
  usuario    Usuario  @relation(fields: [userId], references: [id])
}

model Auditoria {
  id          String   @id @default(uuid())
  userId      String
  ip          String
  localizacao String?
  userAgent   String?
  criadoEm    DateTime @default(now())

  usuario     Usuario  @relation(fields: [userId], references: [id])
}

model Notificacao {
  id         String   @id @default(uuid())
  userId     String
  titulo     String
  mensagem   String
  tipo       TipoNotificacao
  canal      CanalNotificacao
  criadoEm   DateTime @default(now())

  usuario    Usuario  @relation(fields: [userId], references: [id])
}

enum TipoUsuario {
  ADMIN
  ALUNO
}

enum TipoNotificacao {
  COMENTARIO
  RESPOSTA
  CONCLUSAO
  CERTIFICADO
  PERSONALIZADA
}

enum CanalNotificacao {
  EMAIL
  WHATSAPP
}

