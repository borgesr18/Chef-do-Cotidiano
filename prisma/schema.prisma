model Usuario {
  id              String   @id @default(uuid())
  nome            String
  email           String   @unique
  tipo            Perfil   @default(ALUNO)
  favoritos       Favorito[]
  inscricoes      Inscricao[]
  comentarios     Comentario[]
  conclusoes      ConclusaoAula[]
  certificados    Certificado[]
  acessos         AcessoCertificado[]
}

enum Perfil {
  ADMIN
  ALUNO
}

model Curso {
  id            String   @id @default(uuid())
  titulo        String
  descricao     String
  imagem_url    String
  autor         String
  criado_em     DateTime @default(now())
  aulas         Aula[]
  inscricoes    Inscricao[]
  certificados  Certificado[]
}

model Aula {
  id         String   @id @default(uuid())
  titulo     String
  ordem      Int
  video_url  String
  cursoId    String
  curso      Curso    @relation(fields: [cursoId], references: [id])
  comentarios Comentario[]
  conclusoes  ConclusaoAula[]
}

model Comentario {
  id         String   @id @default(uuid())
  conteudo   String
  criado_em  DateTime @default(now())
  usuarioId  String
  aulaId     String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  aula       Aula     @relation(fields: [aulaId], references: [id])
}

model ConclusaoAula {
  id         String   @id @default(uuid())
  usuarioId  String
  aulaId     String
  concluido_em DateTime @default(now())
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  aula       Aula     @relation(fields: [aulaId], references: [id])
}

model Certificado {
  id            String   @id @default(uuid())
  usuarioId     String
  cursoId       String
  criado_em     DateTime @default(now())
  url_publico   String
  qr_code_url   String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])
  curso         Curso    @relation(fields: [cursoId], references: [id])
  acessos       AcessoCertificado[]
}

model AcessoCertificado {
  id              String   @id @default(uuid())
  certificadoId   String
  ip              String
  acessado_em     DateTime @default(now())
  certificado     Certificado @relation(fields: [certificadoId], references: [id])
}

model Inscricao {
  id        String   @id @default(uuid())
  userId    String
  cursoId   String
  criado_em DateTime @default(now())
  usuario   Usuario  @relation(fields: [userId], references: [id])
  curso     Curso    @relation(fields: [cursoId], references: [id])
}

model Receita {
  id          String   @id @default(uuid())
  titulo      String
  imagem_url  String
  criado_em   DateTime @default(now())
  favoritos   Favorito[]
}

model Favorito {
  id         String   @id @default(uuid())
  userId     String
  receitaId  String
  criado_em  DateTime @default(now())
  usuario    Usuario  @relation(fields: [userId], references: [id])
  receita    Receita  @relation(fields: [receitaId], references: [id])
}

