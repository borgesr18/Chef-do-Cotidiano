generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  createdAt  DateTime    @default(now())
  perfil     Perfil?
  receitas   Receita[]   @relation("AutorReceitas")
  favoritos  Favorito[]
  inscricoes Inscricao[]
  progresso  Progresso[]
}

model Perfil {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  tipo      String   // 'admin' ou 'aluno'
  createdAt DateTime @default(now())
}

model Receita {
  id            String     @id @default(uuid())
  titulo        String
  descricao     String?
  imagem_url    String?
  tempo_preparo String?
  dificuldade   String?
  modo_preparo  String?
  ingredientes  String?
  autorId       String
  autor         User       @relation("AutorReceitas", fields: [autorId], references: [id])
  favoritos     Favorito[]
  createdAt     DateTime   @default(now())
}

model Favorito {
  id         String   @id @default(uuid())
  userId     String
  receitaId  String
  user       User     @relation(fields: [userId], references: [id])
  receita    Receita  @relation(fields: [receitaId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, receitaId])
}

model Curso {
  id          String      @id @default(uuid())
  titulo      String
  descricao   String?
  imagem_url  String?
  slug        String      @unique
  gratuito    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  aulas       Aula[]
  inscricoes  Inscricao[]
}

model Aula {
  id         String     @id @default(uuid())
  cursoId    String
  titulo     String
  ordem      Int
  video_url  String?
  descricao  String?
  curso      Curso      @relation(fields: [cursoId], references: [id])
  progresso  Progresso[]
  createdAt  DateTime   @default(now())
}

model Inscricao {
  id        String   @id @default(uuid())
  userId    String
  cursoId   String
  user      User     @relation(fields: [userId], references: [id])
  curso     Curso    @relation(fields: [cursoId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, cursoId])
}

model Progresso {
  id         String   @id @default(uuid())
  userId     String
  aulaId     String
  concluida  Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  aula       Aula     @relation(fields: [aulaId], references: [id])

  @@unique([userId, aulaId])
}

