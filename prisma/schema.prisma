generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id             String           @id @default(uuid())
  nome           String
  email          String           @unique
  tipo           PerfilTipo       @default(ALUNO)
  receitas       Receita[]
  inscricoes     Inscricao[]
  favoritos      Favorito[]
  certificados   Certificado[]
  auditorias     AuditoriaCertificado[]
  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt

  @@map("usuario")
}

model Receita {
  id             String       @id @default(uuid())
  titulo         String
  descricao      String
  imagemUrl      String
  usuarioId      String
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt
  favoritos      Favorito[]

  @@map("receita")
}

model Curso {
  id             String       @id @default(uuid())
  titulo         String
  descricao      String
  imagemUrl      String
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt
  aulas          Aula[]
  inscricoes     Inscricao[]
  certificados   Certificado[]

  @@map("curso")
}

model Aula {
  id             String     @id @default(uuid())
  cursoId        String
  titulo         String
  videoUrl       String
  ordem          Int
  curso          Curso      @relation(fields: [cursoId], references: [id])
  progresso      Progresso[]

  @@map("aula")
}

model Inscricao {
  id             String     @id @default(uuid())
  cursoId        String
  usuarioId      String
  curso          Curso      @relation(fields: [cursoId], references: [id])
  usuario        Usuario    @relation(fields: [usuarioId], references: [id])
  criadoEm       DateTime   @default(now())

  @@map("inscricao")
}

model Favorito {
  id             String     @id @default(uuid())
  usuarioId      String
  receitaId      String
  usuario        Usuario    @relation(fields: [usuarioId], references: [id])
  receita        Receita    @relation(fields: [receitaId], references: [id])
  criadoEm       DateTime   @default(now())

  @@map("favorito")
}

model Comentario {
  id             String     @id @default(uuid())
  aulaId         String
  usuarioId      String
  texto          String
  criadoEm       DateTime   @default(now())
  aula           Aula       @relation(fields: [aulaId], references: [id])
  usuario        Usuario    @relation(fields: [usuarioId], references: [id])

  @@map("comentario")
}

model Progresso {
  id             String     @id @default(uuid())
  aulaId         String
  usuarioId      String
  concluidoEm    DateTime   @default(now())
  aula           Aula       @relation(fields: [aulaId], references: [id])
  usuario        Usuario    @relation(fields: [usuarioId], references: [id])

  @@map("progresso")
}

model Certificado {
  id             String     @id @default(uuid())
  cursoId        String
  usuarioId      String
  dataEmissao    DateTime   @default(now())
  token          String     @unique
  curso          Curso      @relation(fields: [cursoId], references: [id])
  usuario        Usuario    @relation(fields: [usuarioId], references: [id])
  auditorias     AuditoriaCertificado[]

  @@map("certificado")
}

model AuditoriaCertificado {
  id             String     @id @default(uuid())
  certificadoId  String
  email          String
  acessadoEm     DateTime   @default(now())
  certificado    Certificado @relation(fields: [certificadoId], references: [id])

  @@map("auditoria_certificado")
}

enum PerfilTipo {
  ADMIN
  ALUNO
}
