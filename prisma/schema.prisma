generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoPerfil {
  ADMIN
  ALUNO
}

model Usuario {
  id                String        @id @default(uuid())
  nome              String
  email             String        @unique
  telefone          String?
  senhaHash         String
  tipo              TipoPerfil    @default(ALUNO)
  criadoEm          DateTime      @default(now())
  notificaEmail     Boolean       @default(true)
  notificaWhatsapp  Boolean       @default(false)

  favoritos         Favorito[]
  inscricoes        Inscricao[]
  progresso         Progresso[]
  comentarios       Comentario[]
  respostas         Resposta[]
  certificados      Certificado[]
  acessosCertificados AuditoriaAcesso[]
}

model Receita {
  id           String     @id @default(uuid())
  titulo       String
  descricao    String
  imagem_url   String
  criadoEm     DateTime   @default(now())

  favoritos    Favorito[]
}

model Favorito {
  id         String   @id @default(uuid())
  userId     String
  receitaId  String

  usuario    Usuario  @relation(fields: [userId], references: [id])
  receita    Receita  @relation(fields: [receitaId], references: [id])
}

model Curso {
  id           String     @id @default(uuid())
  titulo       String
  descricao    String
  imagem_url   String
  criadoEm     DateTime   @default(now())

  aulas        Aula[]
  inscricoes   Inscricao[]
  certificados Certificado[]
}

model Aula {
  id         String     @id @default(uuid())
  cursoId    String
  titulo     String
  video_url  String
  ordem      Int
  criadoEm   DateTime   @default(now())

  curso      Curso      @relation(fields: [cursoId], references: [id])
  progresso  Progresso[]
  comentarios Comentario[]
}

model Inscricao {
  id        String   @id @default(uuid())
  userId    String
  cursoId   String
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [userId], references: [id])
  curso     Curso    @relation(fields: [cursoId], references: [id])
}

model Progresso {
  id        String   @id @default(uuid())
  userId    String
  aulaId    String
  concluido Boolean  @default(false)
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [userId], references: [id])
  aula      Aula     @relation(fields: [aulaId], references: [id])
}

model Comentario {
  id        String    @id @default(uuid())
  aulaId    String
  userId    String
  texto     String
  criadoEm  DateTime  @default(now())

  aula      Aula      @relation(fields: [aulaId], references: [id])
  autor     Usuario   @relation(fields: [userId], references: [id])
  respostas Resposta[]
}

model Resposta {
  id           String    @id @default(uuid())
  comentarioId String
  userId       String
  texto        String
  criadoEm     DateTime  @default(now())

  comentario   Comentario @relation(fields: [comentarioId], references: [id])
  autor        Usuario    @relation(fields: [userId], references: [id])
}

model Certificado {
  id          String   @id @default(uuid())
  userId      String
  cursoId     String
  token       String   @unique
  criadoEm    DateTime @default(now())
  valido      Boolean  @default(true)

  usuario     Usuario  @relation(fields: [userId], references: [id])
  curso       Curso    @relation(fields: [cursoId], references: [id])
  acessos     AuditoriaAcesso[]
}

model AuditoriaAcesso {
  id             String     @id @default(uuid())
  certificadoId  String
  ip             String
  userAgent      String?
  dataAcesso     DateTime   @default(now())

  certificado    Certificado @relation(fields: [certificadoId], references: [id])
}

model IPBloqueado {
  id          String   @id @default(uuid())
  ip          String   @unique
  motivo      String
  bloqueadoEm DateTime @default(now())
  contador    Int      @default(1)
}
