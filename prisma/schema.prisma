generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                String           @id @default(uuid())
  nome              String
  email             String           @unique
  tipo              TipoUsuario      @default(ALUNO)
  notificacoes      Notificacao[]
  certificados      Certificado[]
  progresso         Progresso[]
  inscricoes        Inscricao[]
  favoritos         Favorito[]
  preferencias      PreferenciaNotificacao?
  auditorias        Auditoria[]
  criadoEm          DateTime         @default(now())
}

model Curso {
  id          String     @id @default(uuid())
  titulo      String
  descricao   String
  imagem_url  String
  aulas       Aula[]
  inscricoes  Inscricao[]
  criadoEm    DateTime   @default(now())
}

model Aula {
  id         String     @id @default(uuid())
  titulo     String
  video_url  String
  curso      Curso      @relation(fields: [cursoId], references: [id])
  cursoId    String
  ordem      Int
  progresso  Progresso[]
  criadoEm   DateTime   @default(now())
}

model Receita {
  id         String     @id @default(uuid())
  titulo     String
  descricao  String
  imagem_url String
  criadoEm   DateTime   @default(now())
  favoritos  Favorito[]
}

model Favorito {
  id        String   @id @default(uuid())
  user      Usuario  @relation(fields: [userId], references: [id])
  userId    String
  receita   Receita  @relation(fields: [receitaId], references: [id])
  receitaId String
  criadoEm  DateTime @default(now())
}

model Inscricao {
  id       String   @id @default(uuid())
  user     Usuario  @relation(fields: [userId], references: [id])
  userId   String
  curso    Curso    @relation(fields: [cursoId], references: [id])
  cursoId  String
  criadoEm DateTime @default(now())
}

model Progresso {
  id         String   @id @default(uuid())
  user       Usuario  @relation(fields: [userId], references: [id])
  userId     String
  aula       Aula     @relation(fields: [aulaId], references: [id])
  aulaId     String
  concluida  Boolean  @default(false)
  criadoEm   DateTime @default(now())
}

model Certificado {
  id         String   @id @default(uuid())
  user       Usuario  @relation(fields: [userId], references: [id])
  userId     String
  curso      Curso    @relation(fields: [cursoId], references: [id])
  cursoId    String
  token      String   @unique
  criadoEm   DateTime @default(now())
  auditorias Auditoria[]
}

model Auditoria {
  id             String        @id @default(uuid())
  certificado    Certificado   @relation(fields: [certificadoId], references: [id])
  certificadoId  String
  usuario        Usuario       @relation(fields: [usuarioId], references: [id])
  usuarioId      String
  ip             String
  criadoEm       DateTime      @default(now())
}

model IPBloqueado {
  id       String   @id @default(uuid())
  ip       String   @unique
  motivo   String?
  criadoEm DateTime @default(now())
}

model Notificacao {
  id         String       @id @default(uuid())
  usuario    Usuario      @relation(fields: [usuarioId], references: [id])
  usuarioId  String
  titulo     String
  mensagem   String
  tipo       TipoNotificacao
  canal      CanalNotificacao
  criadoEm   DateTime     @default(now())
}

model PreferenciaNotificacao {
  id                String   @id @default(uuid())
  usuario           Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId         String   @unique
  emailComentario   Boolean  @default(true)
  emailCertificado  Boolean  @default(true)
  emailAula         Boolean  @default(true)
  whatsappComentario Boolean @default(false)
  whatsappCertificado Boolean @default(false)
  whatsappAula        Boolean @default(false)
  criadoEm          DateTime @default(now())
}

enum TipoUsuario {
  ADMIN
  ALUNO
}

enum TipoNotificacao {
  COMENTARIO
  AULA
  CERTIFICADO
  ADMIN
}

enum CanalNotificacao {
  EMAIL
  WHATSAPP
}

