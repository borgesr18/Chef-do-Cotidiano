# 🔐 Supabase - Autenticação e Client API (uso no frontend)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=chave-publica-anonima-do-supabase

# 🧩 Prisma - Conexão com o banco de dados PostgreSQL do Supabase (uso no backend)
DATABASE_URL="postgresql://usuario:senha@db.seu-projeto.supabase.co:5432/nome_do_banco"

# ⚠️ Observação:
# Substitua:
# - "seu-projeto" pela URL real do seu projeto no Supabase
# - "chave-publica-anonima-do-supabase" pela anon key disponível no Supabase Project Settings → API
# - "usuario", "senha" e "nome_do_banco" pelo que estiver no Connection String do Supabase (Project → Database)
